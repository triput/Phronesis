# Phronesis environment template — copy to .env and fill in values (never commit .env)

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional — defaults to sqlite if unset)
# DATABASE_URL=sqlite:///db.sqlite3

# Google Calendar OAuth (optional — prefer Settings → Calendars)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/calendar/oauth2callback/

# Celery / Redis (P5-04) — required for worker + Beat; optional if using cron fallback
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# CELERY_TASK_ALWAYS_EAGER=False

# Email (optional)
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
